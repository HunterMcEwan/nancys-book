---
layout: layouts/base.njk
title: Family Tree
permalink: /family-tree/
---

<section class="family-tree-page">

<header class="family-tree-page__header">
  <p class="family-tree-page__eyebrow">A hand-laid genealogical map</p>
  <h1>The FitzSimons – Walker family</h1>
  <p class="family-tree-page__lede">
    A scrapbook-style family tree centred on the compiler, <strong>Amy Ann Perry FitzSimons</strong> (1888–1973). Each portrait links back to the album page on which it was originally pasted. The FitzSimons line is traced six generations, from <strong>Christopher the emigrant</strong> (1762–1825) of Dundalk, Ireland, down through Amy to her grandchildren — with Amy's siblings and her first cousins on the FitzSimons side branching out at her own row.
  </p>
  <p class="family-tree-page__hint">
    Drag to pan; scroll, pinch, or use the <span class="family-tree-page__hint-key">+ / − / ⌂</span> controls to zoom. Click any portrait to open the album page where the photograph was pasted.
  </p>
</header>

<div class="family-tree-page__canvas">
<svg id="family-tree-svg"
     class="family-tree-svg"
     xmlns="http://www.w3.org/2000/svg"
     viewBox="0 0 {{ familyTree.viewW }} {{ familyTree.viewH }}"
     role="img"
     aria-label="Family tree centred on Amy Ann Perry FitzSimons">

  <defs>
    <radialGradient id="ft-paper-vignette" cx="50%" cy="50%" r="75%">
      <stop offset="0%"   stop-color="#f6efe1" stop-opacity="0"/>
      <stop offset="100%" stop-color="#cdbf99" stop-opacity="0.18"/>
    </radialGradient>

    <filter id="ft-card-shadow" x="-20%" y="-20%" width="140%" height="140%">
      <feGaussianBlur in="SourceAlpha" stdDeviation="3"/>
      <feOffset dx="2" dy="3" result="offsetblur"/>
      <feComponentTransfer><feFuncA type="linear" slope="0.35"/></feComponentTransfer>
      <feMerge><feMergeNode/><feMergeNode in="SourceGraphic"/></feMerge>
    </filter>
  </defs>

  <rect x="0" y="0" width="{{ familyTree.viewW }}" height="{{ familyTree.viewH }}" fill="#f6efe1"/>
  <rect x="0" y="0" width="{{ familyTree.viewW }}" height="{{ familyTree.viewH }}" fill="url(#ft-paper-vignette)"/>

  <g class="ft-lines">
    {% for line in familyTree.lines %}
      {% if line.type == "marriage" %}
        <line class="ft-line-marriage"
              x1="{{ line.x1 }}" y1="{{ line.y1 }}"
              x2="{{ line.x2 }}" y2="{{ line.y2 }}"/>
      {% elif line.type == "descent" %}
        {% set cpX = (line.midX + line.childX) / 2 %}
        {% set cpY = (line.midY + line.childY) / 2 + 60 %}
        <path class="ft-line-descent"
              d="M {{ line.midX }} {{ line.midY }} Q {{ cpX }} {{ cpY }} {{ line.childX }} {{ line.childY }}"
              fill="none"/>
      {% endif %}
    {% endfor %}
  </g>

  {% for p in familyTree.people %}
    <g class="ft-person" transform="translate({{ p.x }}, {{ p.y }}) rotate({{ p.tilt or 0 }})">
      {% set hasPhoto = p.photo %}
      {% set linkTarget = p.photoLink %}

      {% if linkTarget %}<a href="{{ linkTarget }}" aria-label="Source page for {{ p.name }}">{% endif %}
        <g filter="url(#ft-card-shadow)">
          <rect class="ft-card-backing" x="-84" y="-100" width="168" height="200"/>
          {% if hasPhoto %}
            <image x="-70" y="-86" width="140" height="172"
                   href="{{ p.photo }}"
                   preserveAspectRatio="xMidYMid slice"/>
            <rect class="ft-photo-border" x="-70" y="-86" width="140" height="172"/>
          {% else %}
            <rect class="ft-blank-card" x="-70" y="-86" width="140" height="172"/>
            <text class="ft-blank-mark" x="0" y="0" text-anchor="middle">⁂</text>
          {% endif %}
        </g>
      {% if linkTarget %}</a>{% endif %}

      <text class="ft-name" x="0" y="120" text-anchor="middle">{{ p.name }}</text>
      {% set captionY = 138 %}
      {% if p.nickname %}
        <text class="ft-nickname" x="0" y="{{ captionY }}" text-anchor="middle">&ldquo;{{ p.nickname }}&rdquo;</text>
        {% set captionY = captionY + 16 %}
      {% endif %}
      {% if p.dates %}
        <text class="ft-dates" x="0" y="{{ captionY }}" text-anchor="middle">{{ p.dates }}</text>
        {% set captionY = captionY + 16 %}
      {% endif %}
      {% if p.note %}
        <text class="ft-note" x="0" y="{{ captionY }}" text-anchor="middle">{{ p.note }}</text>
      {% endif %}
    </g>
  {% endfor %}

  <g class="ft-canvas-title" transform="translate(60, 70)">
    <text class="ft-canvas-title__heading">Amy's people</text>
    <text class="ft-canvas-title__sub" y="22">Six generations of the Walker, FitzSimons, Perry, Pritchard, Hampton, and Hammond families</text>
  </g>
</svg>
</div>

</section>

<script src="https://cdn.jsdelivr.net/npm/svg-pan-zoom@3.6.1/dist/svg-pan-zoom.min.js"></script>
<script>
  document.addEventListener("DOMContentLoaded", function () {
    var svg = document.getElementById("family-tree-svg");
    if (!svg || typeof svgPanZoom !== "function") return;
    var panZoomInstance = svgPanZoom(svg, {
      zoomEnabled: true,
      controlIconsEnabled: true,
      fit: true,
      center: true,
      minZoom: 0.3,
      maxZoom: 10,
      zoomScaleSensitivity: 0.25,
      contain: false,
      // Capture wheel events over the SVG so the page does not also scroll
      // while the user is zooming the tree. The library attaches its wheel
      // listener with {passive: false} when this flag is true, which is
      // what modern Chrome requires for preventDefault() to take effect.
      // Portrait <a> links still navigate — only mouse-default (text
      // selection, page scroll) is suppressed.
      preventMouseEventsDefault: true,
    });
    // Re-fit on viewport resize so the tree stays well-framed.
    window.addEventListener("resize", function () {
      panZoomInstance.resize();
      panZoomInstance.fit();
      panZoomInstance.center();
    });
  });
</script>
