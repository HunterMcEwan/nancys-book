<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{% if title %}{{ title }} — {% endif %}{{ site.title }}</title>
  <meta name="description" content="{{ description or site.description }}" />

  {# Typography: refined editorial pairing #}
  {# - EB Garamond: warm Renaissance serif for display & body #}
  {# - IBM Plex Mono: utilitarian counterpoint for metadata #}
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet" />

  <link rel="stylesheet" href="/assets/css/style.css" />
  <link rel="alternate" type="application/rss+xml" title="{{ site.title }}" href="/feed.xml" />
</head>
<body>

<header class="site-header">
  <div class="site-header__inner">
    <a href="/" class="site-header__title">
      <span class="site-header__title-main">The FitzSimons</span>
      <span class="site-header__title-sub">Family Archive</span>
    </a>
    <nav class="site-nav" aria-label="Primary">
      <a href="/" {% if page.url == "/" %}aria-current="page"{% endif %}>Home</a>
      <a href="/books/" {% if page.url.startsWith("/books/") %}aria-current="page"{% endif %}>Books</a>
      <a href="/people/" {% if page.url.startsWith("/people/") %}aria-current="page"{% endif %}>People</a>
      <a href="/places/" {% if page.url.startsWith("/places/") %}aria-current="page"{% endif %}>Places</a>
      <a href="/about/" {% if page.url == "/about/" %}aria-current="page"{% endif %}>About</a>
    </nav>
  </div>
</header>

<main class="site-main">
  {{ content | safe }}
</main>

<footer class="site-footer">
  <div class="site-footer__inner">
    <p>{{ site.attribution }}</p>
    <p class="site-footer__meta">
      Built with <a href="https://www.11ty.dev/">Eleventy</a> ·
      © {{ site.buildYear }}
    </p>
  </div>
</footer>

</body>
</html>
